<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.SlideshowMapper">

    <select id="selectAll" resultType="com.example.entity.Slideshow">
        select slideshow.*, university.name as universityName from slideshow
        left join university on slideshow.university_id = university.id
        <where>
            <if test="universityName != null"> and university.name like concat('%', #{universityName}, '%')</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.Slideshow">
        select * from `slideshow`
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `slideshow`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.Slideshow" useGeneratedKeys="true" keyProperty="id">
        insert into `slideshow`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="universityId != null">university_id,</if>
            <if test="img != null">img,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="universityId != null">#{universityId},</if>
            <if test="img != null">#{img},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.Slideshow">
        update `slideshow`
        <set>
            <if test="universityId != null">
                university_id = #{universityId},
            </if>
            <if test="img != null">
                img = #{img},
            </if>
        </set>
        where id = #{id} 
    </update>

</mapper>