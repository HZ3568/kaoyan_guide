<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.UserCertificationMapper">

    <select id="selectAll" resultType="com.example.entity.UserCertification">
        select user_certification.*, user.name as userName, areas.name as areasName from user_certification
        left join user on user_certification.user_id = user.id
        left join areas on user_certification.areas_id = areas.id
        <where>
            <if test="userId != null"> and user_certification.user_id = #{userId}</if>
            <if test="userName != null"> and user.name like concat('%', #{userName}, '%')</if>
            <if test="status != null"> and user_certification.status like concat('%', #{status}, '%')</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.UserCertification">
        select * from `user_certification`
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `user_certification`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.UserCertification" useGeneratedKeys="true" keyProperty="id">
        insert into `user_certification`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="userId != null">user_id,</if>
            <if test="candidateNumber != null">candidate_number,</if>
            <if test="examinationNumber != null">examination_number,</if>
            <if test="identityNumber != null">identity_number,</if>
            <if test="identityImg != null">identity_img,</if>
            <if test="status != null">status,</if>
            <if test="refuseReason != null">refuse_reason,</if>
            <if test="time != null">time,</if>
            <if test="score != null">score,</if>
            <if test="ranking != null">ranking,</if>
            <if test="areasId != null">areas_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="userId != null">#{userId},</if>
            <if test="candidateNumber != null">#{candidateNumber},</if>
            <if test="examinationNumber != null">#{examinationNumber},</if>
            <if test="identityNumber != null">#{identityNumber},</if>
            <if test="identityImg != null">#{identityImg},</if>
            <if test="status != null">#{status},</if>
            <if test="refuseReason != null">#{refuseReason},</if>
            <if test="time != null">#{time},</if>
            <if test="score != null">#{score},</if>
            <if test="ranking != null">#{ranking},</if>
            <if test="areasId != null">#{areasId},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.UserCertification">
        update `user_certification`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="candidateNumber != null">
                candidate_number = #{candidateNumber},
            </if>
            <if test="examinationNumber != null">
                examination_number = #{examinationNumber},
            </if>
            <if test="identityNumber != null">
                identity_number = #{identityNumber},
            </if>
            <if test="identityImg != null">
                identity_img = #{identityImg},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="refuseReason != null">
                refuse_reason = #{refuseReason},
            </if>
            <if test="time != null">
                time = #{time},
            </if>

            <if test="score != null">
                score = #{score},
            </if>
            <if test="ranking != null">
                ranking = #{ranking},
            </if>
            <if test="areasId != null">
                areas_id = #{areasId},
            </if>
        </set>
        where id = #{id} 
    </update>

</mapper>