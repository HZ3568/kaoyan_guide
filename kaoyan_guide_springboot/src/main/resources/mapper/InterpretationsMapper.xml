<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.InterpretationsMapper">

    <select id="selectAll" resultType="com.example.entity.Interpretations">
        select interpretations.*, categorys.name as categorysName from interpretations
        left join categorys on interpretations.categorys_id = categorys.id
        <where>
            <if test="name != null"> and interpretations.name like concat('%', #{name}, '%')</if>
            <if test="categorysId != null"> and interpretations.categorys_id = #{categorysId}</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.Interpretations">
        select * from `interpretations`
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `interpretations`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.Interpretations" useGeneratedKeys="true" keyProperty="id">
        insert into `interpretations`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="name != null">name,</if>
            <if test="categorysId != null">categorys_id,</if>
            <if test="intro != null">intro,</if>
            <if test="img != null">img,</if>
            <if test="content != null">content,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="time != null">time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="name != null">#{name},</if>
            <if test="categorysId != null">#{categorysId},</if>
            <if test="intro != null">#{intro},</if>
            <if test="img != null">#{img},</if>
            <if test="content != null">#{content},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="time != null">#{time},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.Interpretations">
        update `interpretations`
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="categorysId != null">
                categorys_id = #{categorysId},
            </if>
            <if test="intro != null">
                intro = #{intro},
            </if>
            <if test="img != null">
                img = #{img},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="viewCount != null">
                view_count = #{viewCount},
            </if>
            <if test="time != null">
                time = #{time},
            </if>
        </set>
        where id = #{id} 
    </update>

</mapper>