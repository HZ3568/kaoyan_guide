<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.PolicysMapper">

    <select id="selectAll" resultType="com.example.entity.Policys">
        select policys.*, university.name as universityName, university.avatar as universityAvatar from policys
        left join university on policys.university_id = university.id
        <where>
            <if test="name != null"> and policys.name like concat('%', #{name}, '%')</if>
            <if test="universityId != null"> and policys.university_id = #{universityId}</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.Policys">
        select * from `policys`
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `policys`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.Policys" useGeneratedKeys="true" keyProperty="id">
        insert into `policys`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="name != null">name,</if>
            <if test="universityId != null">university_id,</if>
            <if test="intro != null">intro,</if>
            <if test="content != null">content,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="time != null">time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="name != null">#{name},</if>
            <if test="universityId != null">#{universityId},</if>
            <if test="intro != null">#{intro},</if>
            <if test="content != null">#{content},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="time != null">#{time},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.Policys">
        update `policys`
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="universityId != null">
                university_id = #{universityId},
            </if>
            <if test="intro != null">
                intro = #{intro},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="viewCount != null">
                view_count = #{viewCount},
            </if>
            <if test="time != null">
                time = #{time},
            </if>
        </set>
        where id = #{id} 
    </update>

</mapper>