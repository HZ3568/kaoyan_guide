            <if test="isDoubleFirstClass != null">is_double_first_class,</if>
            <if test="officialWebsite != null">official_website,</if>
            <if test="description != null">description,</if>
            <if test="longitude != null">longitude,</if>
            <if test="latitude != null">latitude,</if>
            <if test="englishName != null">english_name,</if>
            <if test="foundedYear != null">founded_year,</if>
            <if test="affiliation != null">affiliation,</if>
            <if test="leaderInfo != null">leader_info,</if>
            <if test="schoolIntro != null">school_intro,</if>
