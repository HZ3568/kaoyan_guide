            <if test="featuredMajorInfo != null">featured_major_info,</if>
            <if test="firstClassMajorInfo != null">first_class_major_info,</if>
            <if test="graduateHotMajorInfo != null">graduate_hot_major_info,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
